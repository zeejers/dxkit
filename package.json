{
  "name": "@sherbondito/dxkit",
  "version": "1.0.1",
  "description": "Developer experience toolkit — drift detection, context compilation, code review, git archaeology, and pattern harvesting",
  "type": "module",
  "bin": {
    "dxkit": "./bin/dxkit.js",
    "dx": "./bin/dxkit.js"
  },
  "scripts": {
    "build": "tsup src/cli.ts --format esm --dts --clean",
    "dev": "tsx src/cli.ts",
    "prepublishOnly": "npm run build"
  },
  "files": [
    "dist"
  ],
  "keywords": [
    "cli",
    "developer-tools",
    "documentation",
    "code-review",
    "git",
    "static-analysis",
    "ai"
  ],
  "license": "MIT",
  "engines": {
    "node": ">=18"
  },
  "dependencies": {
    "@ai-sdk/anthropic": "^1.0.0",
    "@ai-sdk/openai": "^1.0.0",
    "ai": "^4.0.0",
    "chalk": "^5.3.0",
    "commander": "^12.1.0",
    "diff": "^8.0.4",
    "glob": "^10.3.10",
    "remark": "^15.0.1",
    "remark-stringify": "^11.0.0",
    "unified": "^11.0.5",
    "unist-util-visit": "^5.1.0"
  },
  "devDependencies": {
    "@types/diff": "^7.0.0",
    "@types/node": "^25.5.0",
    "tsup": "^8.0.0",
    "tsx": "^4.7.0",
    "typescript": "^5.4.0"
  }
}
